    <CheatEntry>
      <ID>196</ID>
      <Description>"Auto Button Mash"</Description>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[enable]
alloc(AutoButtonMash,64)
aobscan(ButtonMashAddress1,f3 0f 11 86 0c 2a 00 00 0f b6 86 ? ? ? ? 0f b6 8e)
aobscan(ButtonMashAddress2,72 25 8b 56 ? f3 0f 11 62 ? d9 46 ? 8b 46)
aobscan(ButtonMashAddress3,0f 2f dc 72 0a 5f 5d 8a c3 5b 5e 59 c2 0c 00)
label(ButtonMashAddy1)
label(ButtonMashAddy2)
label(ButtonMashAddy3)
label(OneHundred)
registersymbol(ButtonMashAddy1)
registersymbol(ButtonMashAddy2)
registersymbol(ButtonMashAddy3)

AutoButtonMash:
movss xmm0,[OneHundred]
movss [esi+2a0c],xmm0
movss [esi+3074],xmm0
jmp ButtonMashAddy1+8

OneHundred:
dd (float)100.0

ButtonMashAddress1: //Opening doors, pulling levers, etc...
ButtonMashAddy1:
jmp AutoButtonMash
db 90 90 90

ButtonMashAddress2: //Zombie grabs, opening boxes, etc...
ButtonMashAddy2:
db 90 90

ButtonMashAddress3+3: //Zombie grabs address 2
ButtonMashAddy3:
db 90 90

[disable]

ButtonMashAddy1:
db f3 0f 11 86 0c 2a 00 00
//movss [esi+2a0c],xmm0

ButtonMashAddy2:
db 72 25
//jb +25

ButtonMashAddy3:
db 72 0a
//jb +0a

dealloc(AutoButtonMash)
unregistersymbol(ButtonMashAddy1)
unregistersymbol(ButtonMashAddy2)
unregistersymbol(ButtonMashAddy3)
</AssemblerScript>
