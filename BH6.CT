<CheatTable CheatEngineTableVersion="24">
  <CheatEntries>
    <CheatEntry>
      <ID>49</ID>
      <Description>"Infinite Health"</Description>
      <Options moHideChildren="1" moManualExpandCollapse="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>//Resident Evil 6
//Infinite Health
//Steve Andrew
[enable]
alloc(InfiniteHealth,64)
aobscan(HealthAddress,66 8b 44 24 04 66 29 81 10 0f 00 00 79)
label(HealthAddy)
label(FullPlayerHealth)
label(OneHitKill)
label(HealthRet)
registersymbol(HealthAddy)
registersymbol(OneHitKill)

InfiniteHealth:
cmp [ecx+38],1
jne FullPlayerHealth

//kills enemies in one hit ;)
cmp [OneHitKill],1
je HealthRet+2

//decreases enemy health normally
sub [ecx+f10],ax
jmp HealthRet

FullPlayerHealth:
mov ax,[ecx+f12]
mov [ecx+f10],ax
jmp HealthRet+0b

OneHitKill:
dd 0

HealthAddress+5:
HealthAddy:
jmp InfiniteHealth
db 90 90
HealthRet:

[disable]

HealthAddy:
sub [ecx+f10],ax

dealloc(InfiniteHealth)
unregistersymbol(HealthAddy)
unregistersymbol(OneHitKill)
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>54</ID>
          <Description>"One Hit Kill"</Description>
          <VariableType>4 Bytes</VariableType>
          <Address>OneHitKill</Address>
        </CheatEntry>
      </CheatEntries>
    </CheatEntry>
    <CheatEntry>
