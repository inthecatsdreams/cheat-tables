    <CheatEntry>
      <ID>178</ID>
      <Description>"Infinite Ammo + No Reload + Herbs (Leon)"</Description>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>//Resident Evil 6
//Infinite Ammo + No Reload + Herbs
//Steve Andrew
[enable]
alloc(DualWieldSafety,64)
aobscan(AmmoHerbsAddress,66 29 54 41 0a 79 07 33 d2 66 89 54 41 0a)
aobscan(LeonDualWingShootersSafety,66 01 54 41 0a 0f bf 44 41 0a c2)
label(AmmoHerbsAddy)
label(WingShootersSafetyAddy)
registersymbol(AmmoHerbsAddy)
registersymbol(WingShootersSafetyAddy)

DualWieldSafety:
mov dx,#36
mov [ecx+eax*2+0a],dx
jmp WingShootersSafetyAddy+5

AmmoHerbsAddress:
AmmoHerbsAddy:
db 90 90 90 90 90 eb

LeonDualWingShootersSafety:
WingShootersSafetyAddy:
jmp DualWieldSafety

[disable]

AmmoHerbsAddy:
db 66 29 54 41 0a 79
//sub [ecx+eax*2+0a],dx
//jns *

WingShootersSafetyAddy:
db 66 01 54 41 0a
//add [ecx+eax*2+0a],dx

unregistersymbol(AmmoHerbsAddy)
unregistersymbol(WingShootersSafetyAddy)
</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>91</ID>
      <Description>"Infinite Skill Points"</Description>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>//Resident Evil 6
//Infinite Skill Points
//Steve Andrew
[enable]
alloc(InfiniteSkillPoints,64)
aobscan(SkillPointsAddress,8b 96 ? ? ? ? 03 c0 8b 8c c6 ? ? ? ? 29 8e 88 05)
aobscan(SkillPointsAddress2,8b 8e ? ? ? ? 8b 47 08 29 86 88 05 00 00 51)
label(InfiniteSkillPoints2)
label(SkillPointsAddy)
label(SkillPointsAddy2)
registersymbol(SkillPointsAddy)
registersymbol(SkillPointsAddy2)

InfiniteSkillPoints:
mov ecx,1467f9
mov [esi+588],ecx
jmp SkillPointsAddy+6

InfiniteSkillPoints2:
mov eax,1467f9
mov [esi+588],eax
jmp SkillPointsAddy2+6

SkillPointsAddress+0f:
SkillPointsAddy:
jmp InfiniteSkillPoints
nop

SkillPointsAddress2+9:
SkillPointsAddy2:
jmp InfiniteSkillPoints2
nop

[disable]

SkillPointsAddy:
db 29 8e 88 05 00 00
//mov [esi+588],ecx

SkillPointsAddy2:
db 29 86 88 05 00 00
//mov [esi+588],eax

dealloc(InfiniteSkillPoints)
unregistersymbol(SkillPointsAddy)
unregistersymbol(SkillPointsAddy2)
</AssemblerScript>
