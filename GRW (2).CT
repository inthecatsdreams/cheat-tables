            <CheatEntry>
              <ID>23966</ID>
              <Description>"Process Resources"</Description>
              <Options moHideChildren="1"/>
              <LastState/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]

alloc( ResourcesThread, 0x1000, GRW.exe )
registersymbol( ResourcesThread )
CreateThread( ResourcesThread )
label( ResourcesThreadOff )
registersymbol( ResourcesThreadOff )
label( ResourcesThread_loop )

label( ResRead_do )
registersymbol( ResRead_do )
label( ResRead_do_exit )
label( ResWrite_do )
registersymbol( ResWrite_do )
label( ResWrite_do_exit )

label( dwIdx )
registersymbol( dwIdx )
label( dwResource )
registersymbol( dwResource )
label( dwAmount )
registersymbol( dwAmount )

label( ResTable )
registersymbol( ResTable )

ResourcesThread:
sub rsp,28

ResourcesThread_loop:
mov rcx,A
call Sleep

cmp [ResourcesThreadOff],1
jne short @f
  add rsp,28
  mov [ResourcesThreadOff],2
  ret
@@:

  // VK_NUMPAD7
  mov rcx,67
  call GetAsyncKeyState
  test ax,ax
  je short @f

    call short ResRead_do
    mov rcx,C8
    call Sleep

  @@:
  // VK_NUMPAD9
  mov rcx,69
  call GetAsyncKeyState
  test ax,ax
  je short @f

    call short ResWrite_do
    mov rcx,C8
    call Sleep

  @@:
  jmp ResourcesThread_loop

align 4 CC

ResRead_do:
sub rsp,28
call GetResTabPointer
test rax,rax
je ResRead_do_exit
  mov rcx,rax
  call GetResTable
  test rax,rax
  je short ResRead_do_exit
    xor rbx,rbx
    xor rsi,rsi
    xor rdi,rdi
    mov bl,[rax+1356]     // get table size
    shl bl,3              // multiply by 2^3 = 8
    mov rsi,[rax+134C]    // get first pointer
    lea rdi,[rsi+rbx]     // get last pointer
    @@:
    mov rax,[rsi]
    mov rax,[rax]
    movzx eax,[rax+28]
    mov [dwIdx],rax
    mov rax,[rsi]
    mov rax,[rax]
    mov rax,[rax+38]
    mov [dwResource],rax
    mov rdx,rsi
    mov rcx,[pResConst]   // get base constant
    call ResourceRead
    mov [dwAmount],eax
    lea rbx,[ResTable]    // store values in a table for display
    mov rcx,[dwIdx]
    mov [rbx+rcx*8],eax
    add rsi,8
    cmp rsi,rdi
    jne short @b
ResRead_do_exit:
add rsp,28
ret

align 4 CC

ResWrite_do:
sub rsp,28
call GetResTabPointer
test rax,rax
je short ResWrite_do_exit
  mov rcx,rax
  call GetResTable
  test rax,rax
  je short ResWrite_do_exit
    xor rbx,rbx
    xor rsi,rsi
    xor rdi,rdi
    mov rsi,[rax+134C]    // get first pointer
    mov bl,[rax+1356]     // get table size
    shl bl,3              // multiply by 2^3 = 8
    lea rdi,[rsi+rbx]     // get last pointer
    @@:
    mov rax,[rsi]
    mov rcx,[rax]
    movzx ecx,[rcx+28]
    shl cl,3
    lea rbx,[ResTable]    // store values in a table for display
    mov r9,[rbx+rcx]      // get value to write
    mov r8,[rsi]
    mov r8,[r8]
    mov rcx,[pResConst]
    mov edx,[rcx+10]
    mov rcx,[rcx+18]
    call ResourceWrite
    add rsi,8
    cmp rsi,rdi           // loop till all 4 resources were processed
    jne short @b
ResWrite_do_exit:
add rsp,28
ret

align 4 CC

ResourcesThreadOff:
dd 0
dwIdx:
dq 0
dwResource:
dq 0
dwAmount:
dq 0

align 4 CC

ResTable:
dq 0
dq 0
dq 0
dq 0

[DISABLE]

{$lua}

if not syntaxcheck then
  local starttime = getTickCount()

  if readInteger( "ResourcesThreadOff" ) == 0 then --could be 2 already
    writeInteger( "ResourcesThreadOff", 1 ) --tell the thread to kill itself
  end

  while( getTickCount() &lt; starttime + 1000 ) and ( readInteger( "ResourcesThreadOff" ) ~= 2 ) do --wait till it has finished
    sleep( 20 )
  end

  if( getTickCount() &gt; starttime + 1000 ) then --could happen when the window is shown
    showMessage( 'Disabling the thread failed!' )
    error( 'Thread disabling failed!' )
  end
    sleep( 1 )
  end

{$asm}

unregistersymbol( ResTable )

unregistersymbol( dwAmount )
unregistersymbol( dwResource )
unregistersymbol( dwIdx )

unregistersymbol( ResWrite_do )
unregistersymbol( ResRead_do )

unregistersymbol( ResourcesThreadOff )
unregistersymbol( ResourcesThread )
dealloc( ResourcesThread )
</AssemblerScript>
