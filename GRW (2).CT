KeyHandlerThread_loop:
mov rcx,A
call Sleep

cmp [KeyHandlerOff],1
jne short @f
  add rsp,28
  mov [KeyHandlerOff],2
  ret
@@:

  // VK_NUMPAD0
  mov rcx,60
  call GetAsyncKeyState
  test ax,ax
  je short @f

    call short ReadResources_do
    mov rcx,C8
    call Sleep
    jmp short KeyHandlerThread_return

  @@:
  // VK_NUMPAD1
  mov rcx,61
  call GetAsyncKeyState
  test ax,ax
  je short @f

    mov rcx,[amount_all]
    call short WriteResources_do
    mov rcx,C8
    call Sleep
    jmp short KeyHandlerThread_return

  @@:
  // VK_NUMPAD2
  mov rcx,62
  call GetAsyncKeyState
  test ax,ax
  je short @f

    mov rcx,[idx]
    call short ReadResource_do
    mov rcx,C8
    call Sleep
    jmp short KeyHandlerThread_return

  @@:
  // VK_NUMPAD3
  mov rcx,63
  call GetAsyncKeyState
  test ax,ax
  je short @f

    mov rcx,[idx]
    mov rdx,[amount]
    call short WriteResource_do
    mov rcx,C8
    call Sleep

  KeyHandlerThread_return:
  jmp KeyHandlerThread_loop

