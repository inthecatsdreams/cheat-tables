if not syntaxcheck then
  if getAddressSafe( "GetBhvGhostRefsHook" ) == nil then
    local Sym = GetAssemblySpot()
    registerSymbol( "GetBhvGhostRefsHook", Sym, true )
  end
end

{$asm}

label( PBYTE_GetBhvGhostRefs_o )
registersymbol( PBYTE_GetBhvGhostRefs_o )

label( o )
registersymbol( o )
label( p )
registersymbol( p )
label( q )
registersymbol( q )

GetBhvGhostRefsHook:
mov [o],rbx
mov [p],rcx
mov rax,[rcx+30]
mov [q],rax
PBYTE_GetBhvGhostRefs_o:
readmem( PBYTE_GetBhvGhostRefs, 6 )
jmp PBYTE_GetBhvGhostRefs+6

db CC CC CC CC

o:
dq 0
p:
dq 0
q:
dq 0

db DE AD C0 DE

PBYTE_GetBhvGhostRefs:
jmp GetBhvGhostRefsHook
db 90

[DISABLE]

PBYTE_GetBhvGhostRefs:
readmem( PBYTE_GetBhvGhostRefs_o, 6 )

unregistersymbol( q )
unregistersymbol( p )
unregistersymbol( o )
unregistersymbol( PBYTE_GetBhvGhostRefs_o )
</AssemblerScript>
          <CheatEntries>
            <CheatEntry>
              <ID>23934</ID>
              <Description>"God Mode"</Description>
              <LastState Activated="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]

{$lua}

if not syntaxcheck then
  if getAddressSafe( "GodModeHook" ) == nil then
    local Sym = GetAssemblySpot()
    registerSymbol( "GodModeHook", Sym, true )
  end
end

{$asm}

label( PBYTE_GodMode_o )
registersymbol( PBYTE_GodMode_o )

GodModeHook:
push rax
mov rax,[p]
test rax,rax
je short @f
  cmp rax,rcx // just in case
  jne short @f
    mov byte ptr [rcx+201],1
    //mov byte ptr [p+1F3],1 -- this is for instant actions; becomes 1, then 0 when action finishes
    //mov byte ptr [p+78],1  -- you get God and invisibility (sound is still detected)
@@:
pop rax
PBYTE_GodMode_o:
readmem( PBYTE_GodMode, 5 )
jmp PBYTE_GodMode+5

db DE AD C0 DE

PBYTE_GodMode:
jmp GodModeHook

[DISABLE]

[p]+201:
db 0

PBYTE_GodMode:
readmem( PBYTE_GodMode_o, 5 )

unregistersymbol( PBYTE_GodMode_o )

