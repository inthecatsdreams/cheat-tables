  function Init()
    gameProcess = "GRW.exe"
    gameModule = getAddress( gameProcess )
    moduleSize = getModuleSize( gameProcess )
    -- time to fetch the helpers
    GetCaves()
    GetPBYTE_GetBhvGhostRefs()
    GetPBYTE_GodMode()
    GetPBYTE_SkipVehicleDamage()
    GetPBYTE_SkipMissileDamage()
    GetPBYTE_SkipMobilePartsDamage()
    GetPBYTE_Immunity()
    GetPBYTE_NoReload()
