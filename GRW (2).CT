if not syntaxcheck then

  function _readInteger( Input )
    -- thanks, Pox!
    local Value = readInteger( Input )
    if Value &lt; 0x80000000 then return Value
    else return Value - 0x100000000 end
  end

  function AOBScanEx( aob, p, a, n, s, e, pb )
    -- thanks, panraven!
    -- see: https://forum.cheatengine.org/viewtopic.php?t=577536
    local p, a, n, s, e = p or '*X*W', a or fsmNotAligned, n or '0', s or 0x0, e or 0xffffffffffffffff
    local ms = pb and createMemScan( pb ) or createMemScan()
    local fl = createFoundList( ms )
    ms.firstScan( soExactValue, vtByteArray, nil, aob, nil, s, e, p, a, n, true, false, false, false )
    ms.waitTillDone()
    fl.initialize()
    local result = nil
    if fl ~= nil and fl.getCount() &gt; 0 then
      result = createStringlist()
      for i = 1, fl.getCount() do result.add( fl.getAddress( i-1 ) ) end
    end
    fl.destroy()
    ms.destroy()
    return result
  end

  function GetAssemblySpot( p )
    local gameProcess = "GRW.exe"
    local gameModule = getAddress( gameProcess )
    local pStart = gameModule + 0x500
    local pEnd = pStart + 0xB00
    local pScan = AOBScanEx( "DEADC0DE00", nil, nil, nil, pStart, pEnd )
    if pScan == nil then
      p = pStart
    else
      p = tonumber( pScan[0], 16 ) + 0x4
    end
    return p
  end

  function GetCaves()
    local pCave0 = gameModule + 0x500
    fullAccess( gameModule, 0xB00 )
    unregisterSymbol( "Cave0" )
    registerSymbol( "Cave0", pCave0, true )
    -- find &lt;/application&gt;&lt;/assembly&gt;
    local hkCave = AOBScanEx( "3C2F6170706C69636174696F6E3E3C2F617373656D626C793E", nil, nil, nil, gameModule, gameModule + moduleSize )
    if hkCave ~= nil then
      local t = tonumber( hkCave[0], 16 ) + 0x2A
      fullAccess( t, 0xC00 )
      unregisterSymbol( "Cave1" )
      registerSymbol( "Cave1", t, true )
      --print( string.format( "GetCaves -&gt; AOB1: 0x%X", t ) )
    else
      print( "GetCaves -&gt; AOB1 not found!" )
    end
  end

