{$asm}

label( PBYTE_NoSplashDamage_o )
registersymbol( PBYTE_NoSplashDamage_o )

NoSplashDamageHook:
push rax
mov rax,[o]
mov rax,[rax+10]
cmp [rbx+28],rax
pop rax
jne short @f
  ret
PBYTE_NoSplashDamage_o:
readmem( PBYTE_NoSplashDamage, 5 )
jmp PBYTE_NoSplashDamage+5

db DE AD C0 DE

PBYTE_NoSplashDamage:
jmp NoSplashDamageHook

[DISABLE]

PBYTE_NoSplashDamage:
