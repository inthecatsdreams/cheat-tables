 ------------------------------ ENABLE ------------------------------
[ENABLE]
{$asm}
intSuperStaffHook:
	dd 58D0214E // Custom Headers
	dd 0BC07F00 // Custom Status Sync
	//
	dd 58D0214E // Combat Headers
	dd 58D2F5CE // R&amp;D Headers
	dd 58D8584E // Base Dev. Headers
	dd 58D6FACE // Support Headers
	dd 58D85B4E // Intel Headers
	dd 58D77E4E // Medical Headers
	dd 0BC07F00 // All Status Sync
flgSuperStaffHook:
	db 00 // Flag
// 00:Disabled
// 01:Custom
// 02:Combat
// 03:R&amp;D
// 04:Base Dev.
// 05:Support
// 06:Intel
// 07:Medical
{$lua}
------------------------------ DISABLE ------------------------------
[DISABLE]
