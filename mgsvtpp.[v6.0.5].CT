                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript Async="1">{$lua}
if syntaxcheck then return end
I2CETableCEA.autoAssembleFile('DeltaWrtHook.CEA', memrec)
------------------------------ ENABLE ------------------------------
[ENABLE]
{$asm}
fltDeltaWrtHook+10:
	dd (float)1.75 // Player Multiplier
fltDeltaWrtDHHook+10:
	dd (float)1.75 // D-Horse Multiplier
fltDeltaWrtDWHook+10:
	dd (float)2.5 // D-Walker Multiplier
{$lua}
------------------------------ DISABLE ------------------------------
[DISABLE]
</AssemblerScript>
