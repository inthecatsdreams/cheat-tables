          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>85359</ID>
              <Description>"Print Game Module &amp; Table Info  ()-&gt;"</Description>
              <LastState/>
              <Color>008000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript Async="1">{$lua}
[Enable]
if syntaxcheck then return end
local pm, bs, fp, ma, fv = Helpers.getGameModuleInfoStrs()
print(string.format('Process:        %s', process))
print(string.format('Path To File:   %s', fp:sub(2, #fp)))
print(string.format('Process Module: %s', pm))
print(string.format('Module Address: %016X', ma))
print(string.format('File Version:   %s', fv))
print(string.format('CE Version:     %.1f', getCEVersion()))
print(string.format('Table: %s  %s', TABLE_NAME, TABLE_VERSION))
Helpers.mrAutoDisable(memrec.ID)
[Disable]
</AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>85360</ID>
              <Description>"Print Game Modules  ()-&gt;"</Description>
              <LastState/>
              <Color>008000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript Async="1">{$lua}
[Enable]
if syntaxcheck then return end
local ind = '    '
local modules = enumModules()
for i = 1, #modules do
	if modules[i].Is64Bit then
		print(modules[i].Name..'    x64')
	else
		print(modules[i].Name..'    x32')
	end
	print(ind..string.format('%016X', modules[i].Address))
	print(ind..modules[i].PathToFile:sub(2, #modules[i].PathToFile))
end
Helpers.mrAutoDisable(memrec.ID)
[Disable]
</AssemblerScript>
            </CheatEntry>
