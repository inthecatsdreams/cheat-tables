local Timestamp = 0
local adrsBase = "[[[[TheKillingAntidote-Win64-Shipping.exe+04834260]+0]+118]+358]"
function TimerCheck()
  local ts = -1
  local zs = -1
  if readPointer(adrsBase) ~= nil and readPointer(adrsBase) ~= 0 then
     ts = readFloat(adrsBase .. "+114") or 0 --timestamp
     zs = readFloat(adrsBase .. "+994") or 0 --damagestamp
     if ts &gt; 0 and ts &gt;= Timestamp and zs &gt; 0 then
        Timestamp = readFloat(adrsBase .. "+114")
        return true
     end
  else
      Timestamp = 0 -- Need to do this as game has reloaded and Timestamp is dated
  end
  -- print(ts .. " --&gt; " .. Timestamp .. " --&gt; " .. zs);
  return false
end


local arr = {}    -- new array
function ResetArray()
    for i = 0, 60 do
      arr[i] = 0
    end
end

[ENABLE]
   Timestamp = 0
   ResetArray()

   local adrsPnt = "[[" .. adrsBase .. "+6D8]+B0]"
   itemTimer = createTimer()
   itemTimer.setInterval(100)
   itemTimer.onTimer = function()
     UpdateCount()
   end

   function UpdateCount()
     if TimerCheck() and readPointer(adrsPnt) ~= nil and readPointer(adrsPnt) ~= 0 then
       for i = 0, 80, 1 do
          if TimerCheck() and readPointer(adrsPnt) ~= nil and readPointer(adrsPnt) ~= 0 then
            -- local adrsAmmo = adrsPnt .. "+" .. string.format("%X", 8 + i * 20)
            local adrsAmmo = adrsPnt .. "+" .. string.format("%X", 8 + i * 20)
            local stackSize = readBytes(adrsAmmo) or 0 -- Fix for the attempt to compare nil with number
            if arr[i] == 2 and stackSize == 1 then
               writeBytes(adrsAmmo, 2)
               arr[i] = 2
            else
               arr[i] = stackSize
            end
          end
       end
     else
         ResetArray()
     end
   end

[DISABLE]
   itemTimer.destroy()
