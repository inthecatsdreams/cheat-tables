          <Description>"Invincible (Timeout on All Damage and Zombie attacks. Includes Falls &amp; Explosions)"</Description>
          <Color>0000FF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{$lua}
if syntaxcheck then return end

local Timestamp = 0
local adrsBase = "[[[[TheKillingAntidote-Win64-Shipping.exe+04834260]+0]+118]+358]"
function TimerCheck()
  local ts = -1
  local zs = -1
  if readPointer(adrsBase) ~= nil and readPointer(adrsBase) ~= 0 then
     ts = readFloat(adrsBase .. "+114") or 0 --timestamp
     zs = readFloat(adrsBase .. "+994") or 0 --damagestamp
     if ts &gt; 0 and ts &gt;= Timestamp and zs &gt; 0 then
        Timestamp = readFloat(adrsBase .. "+114")
        return true
     end
  else
      Timestamp = 0 -- Need to do this as game has reloaded and Timestamp is dated
  end
  -- print(ts .. " --&gt; " .. Timestamp .. " --&gt; " .. zs);
  return false
end

[ENABLE]
   Timestamp = 0
   invTimer = createTimer()
   invTimer.setInterval(500)
   invTimer.onTimer = function()
     if TimerCheck() then
        writeFloat(adrsBase .. "+994" , readFloat(adrsBase .. "+114") + 10)
      end
   end
[DISABLE]
   invTimer.destroy()
   if TimerCheck() then
      writeFloat(adrsBase .. "+994", readFloat(adrsBase .. "+114"))
   end
</AssemblerScript>
