function ValidValues()
  if TimerCheck() == false then return false end
  if readPointer(adrsBase) ~= nil and readPointer(adrsBase) ~= 0 then
     return true
  else
     return false
  end
end

function SetExpMult(v)
   if ValidValues() then
      local expMult = readFloat(adrsBase .. "+BC8") or 0
      if expMult == 1 or expMult == 9001 then
      -- if expMult &gt;= 1 and expMult &lt; 10 then
         writeFloat(adrsBase .. "+BC8" , v)
      end
   end
end

