createthread(TEW2_movementSpeedKeys_keylistener_mem)
label(keylistenerstart)
label(keylistenerend)
label(keylistenerexit)

TEW2_movementSpeedKeys_keylistener_mem:
sub rsp,28

keylistenerstart:
mov rcx,14 //CAPS LOCK key //05 //X1 Mouse Button
push rcx
call GetAsyncKeyState
add rsp,08
shr ax,#15
mov rcx,bMovemenySpeedModKey1
mov [rcx],al

keylistenerend:
mov rcx,#100
call Sleep
cmp dword ptr [bEndThread_TEW2_movementSpeedKeys_keylistener_mem],1
jne keylistenerstart

keylistenerexit:
add rsp,28
mov dword ptr [bEndThread_TEW2_movementSpeedKeys_keylistener_mem],2
ret

///
bEndThread_TEW2_movementSpeedKeys_keylistener_mem:
dd 0
///

 
 
[DISABLE]
//code from here till the end of the code will be used to disable the cheat
//obtained from SubBeam's ACS script - start//
{$lua}

if( syntaxcheck == false ) then --actual execution
  local starttime = getTickCount()

if readInteger( "bEndThread_TEW2_movementSpeedKeys_keylistener_mem" ) == 0 then --could be 2 already
  writeInteger( "bEndThread_TEW2_movementSpeedKeys_keylistener_mem", 1 ) --tell the thread to kill itself
end

while( getTickCount() &lt; starttime + 1000 ) and ( readInteger( "bEndThread_TEW2_movementSpeedKeys_keylistener_mem" ) ~=2 ) do --wait till it has finished
  sleep( 20 )
end

if( getTickCount() &gt; starttime + 1000 ) then --could happen when the window is shown
  showMessage( 'Disabling the thread failed!' )
  error( 'Thread disabling failed!' )
end
  sleep( 1 )
end

{$asm}
//obtained from SubBeam's ACS script - end//

