//modified from TheyCallMeTim13's lua keylistener script
//http://fearlessrevolution.com/viewtopic.php?f=4&amp;t=6041&amp;start=60#p62657
{$lua}
local function oneHitKillKeyLuaThread(thread)
    while bEndOneHitKillKeyLuaThread do
          if ( isKeyPressed(VK_CAPITAL) ) then
              writeBytes("bOneHitKillKey" ,1)
          else
              writeBytes("bOneHitKillKey" ,0)
          end
    end
    thread.terminate()
end
