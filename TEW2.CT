            <CheatEntry>
              <ID>459</ID>
              <Description>"no-clip (numpad0.)"</Description>
              <Options moHideChildren="1"/>
              <LastState/>
              <Color>FF0000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
//code from here to '[DISABLE]' will be used to enable the cheat
define(noclipbasespeed,(float)0.2)
define(shiftkeynoclipspeedmultiplier,(float)3)
define(capslockkeynoclipspeedmultiplier,(float)0.5)

alloc(values_noclip,1024,"TEW2.exe")
label(dNoClipSpeedMultiplier)
registersymbol(dNoClipSpeedMultiplier)
label(dXForce)
registersymbol(dXForce)
label(dYForce)
registersymbol(dYForce)
label(dZForce)
registersymbol(dZForce)

///*****************************************************///
values_noclip:
dNoClipSpeedMultiplier:
dd (float)1
dXForce:
dd 0
dYForce:
dd 0
dZForce:
dd 0

///*****************************************************///
aobscanmodule(playerNVReadAOB,TEW2.exe,48 8B 01 FF ** ** 4C 8D ** ** ** ** ** 4D 8B C5)
registersymbol(playerNVReadAOB)

aobscanmodule(someCoordsWrite3AOB,TEW2.exe,0F 28 CA 0F 28 02 48 8B D9 0F 29 ** ** ** ** ** 48 85 C0 74)
registersymbol(someCoordsWrite3AOB)

alloc(newmem,2048,someCoordsWrite3AOB+9) //"TEW2.exe"+F4D253)
label(returnhere)
label(originalcode_noclip)
registersymbol(originalcode_noclip)
label(exit)

newmem: //this is allocated memory, you have read,write,execute access
//place your code here
push rax
mov rax,pPlayerInfo3
cmp [rax],rcx
pop rax
jne end

//freeze coord
db 0F 28
readmem(someCoordsWrite3AOB+b,5)
//movaps xmm0,[rcx+120]

//store registers, xmms
push rax
push rbx
push r8
push r9
sub rsp,10
movdqu dqword [rsp],xmm3
xorps xmm3,xmm3
sub rsp,10
movdqu dqword [rsp],xmm4
xorps xmm4,xmm4

//do y
//get y movement
mov r8,dYForce
test r8,r8
jz @f
movss xmm4,[r8]
shufps xmm4,xmm4,c0 //broadcast except 4th

//apply speed
mov eax,noclipbasespeed
movd xmm3,eax
shufps xmm3,xmm3,00 //broadcast
mulps xmm4,xmm3
movss xmm3,[dNoClipSpeedMultiplier]
shufps xmm3,xmm3,c0 //broadcast except 4th
mulps xmm4,xmm3

//apply vector
mov r9,pSomeMovementInfo1
mov r9,[r9]
test r9,r9
jz @f
xor rbx,rbx
mov rax,playerNVReadAOB
mov ebx,[rax+9]
movups xmm3,[r9+rbx] //d358
mulps xmm4,xmm3

//update new coord
addps xmm0,xmm4

//do x
//get x movement
mov r8,dXForce
test r8,r8
jz @f
movss xmm4,[r8]
shufps xmm4,xmm4,e0 //copy to 2nd

//apply speed
mov eax,noclipbasespeed
movd xmm3,eax
shufps xmm3,xmm3,e0 //copy to 2nd
mulps xmm4,xmm3
movss xmm3,[dNoClipSpeedMultiplier]
shufps xmm3,xmm3,00 //broadcast
mulps xmm4,xmm3

//apply vector
mov r9,pSomeMovementInfo1
mov r9,[r9]
test r9,r9
jz @f
xor rbx,rbx
mov rax,playerNVReadAOB
mov ebx,[rax+9]
movups xmm3,[r9+rbx+c] //d364
mulps xmm4,xmm3

//update new coord
addps xmm0,xmm4

//do z
//get z direction
movss xmm4,[dZForce]
shufps xmm4,xmm4,c6 //place z direction to 3rd element

//apply speed
mov eax,noclipbasespeed
movd xmm3,eax
shufps xmm3,xmm3,00
